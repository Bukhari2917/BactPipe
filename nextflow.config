params {
    reads = "data/*_R{1,2}.fastq"
    outdir = "results"
}

process {
    cpus = 4
    memory = 8.GB
    time = 2.h
    
    withName: ASSEMBLY {
        memory = 32.GB
        cpus = 8
        time = 4.h
    }
    
    withName: ANTISMASH {
        memory = 16.GB
        cpus = 8
    }
    
    withName: EGGNOG {
        memory = 16.GB
        cpus = 8
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "envs/environment.yml"
    }
    docker {
        docker.enabled = true
    }
}
