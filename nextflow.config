# 2. Add this ENTIRE content to the file
cat > ~/bacteria_test/BactPipe/nextflow.config << 'EOF'
// Docker settings for antiSMASH
docker.enabled = true

process {
    withName: ANTISMASH {
        container = 'antismash/antismash:latest'
        conda = false
    }
}

// Default parameters
params {
    reads = "data/*_R{1,2}.fastq"
    outdir = "results"
}

// Conda profile
profiles {
    conda {
        conda.enabled = true
        process.conda = "envs/environment.yml"
    }
    docker {
        docker.enabled = true
    }
}
EOF
