params {
    reads = "data/*_R{1,2}.fastq"
    outdir = "results"
}

process {
    cpus = 8
    memory = 16.GB
    withName: ASSEMBLY {
        memory = 32.GB
        cpus = 8
    }
}

profiles {
    conda {
        conda.enabled = true
    }
    docker {
        docker.enabled = true
    }
}
