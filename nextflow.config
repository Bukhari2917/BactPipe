cat > nextflow.config << 'EOF'
//============================================================
// BactPipe Configuration
//============================================================

manifest {
    name = 'BactPipe'
    author = 'Bukhari2917'
    description = 'Universal Bacterial Genome Analysis Pipeline'
    version = '2.0.0'
}

// Default parameters
params {
    reads = "data/raw_fastq/*_{R1,R2}*.fastq.gz"
    outdir = "results"
    threads = 8
    memory = "32.GB"
}

// Process settings
process {
    cpus = params.threads
    memory = params.memory
    errorStrategy = 'retry'
    maxRetries = 2
}

// Profiles
profiles {
    standard {
        process.cpus = 4
        process.memory = '16.GB'
    }
    large {
        process.cpus = 16
        process.memory = '64.GB'
    }
    test {
        params.reads = "test_data/*_{R1,R2}*.fastq.gz"
        params.outdir = "test_results"
        process.cpus = 2
        process.memory = '8.GB'
    }
}

// Timeline and reports
report.enabled = true
trace.enabled = true
timeline.enabled = true
EOF
